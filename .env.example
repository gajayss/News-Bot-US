NEWS_SOURCE_MODE=sample
FINNHUB_KEY=
NEWS_POLL_SEC=20
WATCHLIST=NVDA,TSLA,AAPL,QQQ
CONFIDENCE_THRESHOLD=0.55
NEGATIVE_STOCK_THRESHOLD=-0.70
POSITIVE_STOCK_THRESHOLD=0.70
NEGATIVE_OPTION_THRESHOLD=-0.75
POSITIVE_OPTION_THRESHOLD=0.75
MAX_SIGNALS_PER_EVENT=3

KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_CANO=
KIS_ACNT_PRDT_CD=01
KIS_OVERSEAS_EXCHANGE=NASD
KIS_OVERSEAS_ORDER_BUY_TR_ID=TTTT1002U
KIS_OVERSEAS_ORDER_SELL_TR_ID=TTTT1006U
KIS_ORDER_PRICE=0
KIS_ORDER_TYPE=00
KIS_SIMULATE=true

OPTION_BROKER_MODE=command
KIWOOM_COMMAND=python news_bridge/adapters/kiwoom_command_adapter.py --payload {payload_file} --target C:/trade/us_option_bot/live_order_entry.py --mode named-args --arg-map-file kiwoom_arg_map.sample.json
KIWOOM_COMMAND_TIMEOUT_SEC=25
KIWOOM_COMMAND_WORKING_DIR=
KIWOOM_COMMAND_SUCCESS_RETURNCODES=0
KIWOOM_COMMAND_CAPTURE_STDOUT_JSON=true
KIWOOM_COMMAND_EXTRA_ENV_JSON={}
KIWOOM_COMMAND_DELETE_PAYLOAD_AFTER_RUN=false

KIWOOM_WEBHOOK_URL=http://127.0.0.1:8011/trade/option
KIWOOM_REST_BASE_URL=https://api.kiwoom.com
KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=
KIWOOM_ACCOUNT_NO=
KIWOOM_OPTION_ORDER_TR_CODE=

# --- Rate Limiter ---
MAX_ORDERS_PER_MINUTE=5
SYMBOL_COOLDOWN_SEC=60

# --- Telegram Alerts (optional, leave empty to disable) ---
TELEGRAM_BOT_TOKEN=
